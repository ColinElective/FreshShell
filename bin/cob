#!/bin/bash

if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "Not inside a Git repository."
  exit 1
fi

force_checkout=""
branch_query=""
prune_worktree=""

# Parse arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    -f|--force)
      force_checkout="--force"
      shift
      ;;
    --prune)
      prune_worktree="true"
      shift
      ;;
    *)
      if [ -z "$branch_query" ]; then
        branch_query="$1"
        shift
      else
        echo "Unexpected argument: $1"
        exit 1
      fi
      ;;
  esac
done

if [ -z "$branch_query" ]; then
  echo "Usage: cob <branch-name-fragment> [-f|--force] [--prune]"
  exit 1
fi

branch_names=()
matches=()

while IFS= read -r line; do
  branch=$(cut -d'|' -f1 <<< "$line")
  display=$(cut -d'|' -f2 <<< "$line")
  branch_names+=("$branch")
  matches+=("$display")
done < <(
  git for-each-ref --sort=committerdate \
    --format='%(refname:short)|%(refname:short) - %(committerdate:relative) - %(objectname:short) - %(contents:subject)' \
    refs/heads/ | grep -i ".*$branch_query.* -" | grep -Ev '^(bu-|backup)'
)

count=${#matches[@]}
branch_name=""

if [ "$count" -eq 0 ]; then
  echo "No matching branches found for '$branch_query'"
  exit 1
elif [ "$count" -eq 1 ]; then
  branch_name="${branch_names[0]}"
else
  echo "Multiple branches found:"
  for i in "${!matches[@]}"; do
    echo "[$i] ${matches[i]}"
  done
  echo -n "Choose a branch number to checkout: "
  read -r selection
  if [[ "$selection" =~ ^[0-9]+$ && "$selection" -ge 0 && "$selection" -lt $count ]]; then
    branch_name="${branch_names[$selection]}"
  else
    echo "Invalid selection"
    exit 1
  fi
fi

echo "git checkout $force_checkout $branch_name"

# Capture combined output so we can inspect failures
checkout_output=$(git checkout $force_checkout "$branch_name" 2>&1)
checkout_status=$?
echo "$checkout_output"

# If checkout failed because the branch is tied to an existing worktree,
# and --prune was requested, offer to remove that worktree and retry.
if [ "$checkout_status" -ne 0 ] && [ -n "$prune_worktree" ] \
   && echo "$checkout_output" | grep -q "is already used by worktree at"; then

  worktree_path=$(echo "$checkout_output" | sed -n "s/.*is already used by worktree at '\(.*\)'.*/\1/p")

  if [ -z "$worktree_path" ]; then
    echo "Could not determine the worktree path from the error output."
    exit "$checkout_status"
  fi

  echo -n "Do you want to 'rm -rf $worktree_path'? [y/N] "
  read -r answer
  case "$answer" in
    y|Y|yes|Yes|YES)
      rm -rf "$worktree_path"
      git worktree prune
      echo "git checkout $force_checkout $branch_name"
      git checkout $force_checkout "$branch_name"
      exit $?
      ;;
    *)
      echo "Aborted."
      exit "$checkout_status"
      ;;
  esac
fi

exit "$checkout_status"